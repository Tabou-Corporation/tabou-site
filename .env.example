# ─── Base de données ──────────────────────────────────────────────────────────
# Neon PostgreSQL : https://neon.tech
# Copier la "Connection string" (pooled) depuis le dashboard Neon
DATABASE_URL="postgresql://user:password@host/tabou?sslmode=require"

# Neon uniquement — décommentez si vous utilisez Prisma en mode serverless
# DIRECT_URL="postgresql://user:password@host/tabou?sslmode=require"

# ─── Auth.js ──────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
AUTH_SECRET="remplacez-par-une-vraie-cle-secrete"

# ─── EVE Online SSO ───────────────────────────────────────────────────────────
# 1. Aller sur https://developers.eveonline.com/
# 2. Créer une application ("Create Application")
# 3. Name : "Tabou Corporation Site"
# 4. Connection Type : "Authentication Only"
# 5. Callback URL : http://localhost:3000/api/auth/callback/eveonline
#    (en production : https://votre-domaine.fr/api/auth/callback/eveonline)
# 6. Scopes : publicData
EVE_CLIENT_ID="votre-client-id-eve-sso"
EVE_CLIENT_SECRET="votre-client-secret-eve-sso"

# ─── Application ──────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# En production uniquement :
# NEXTAUTH_URL="https://votre-domaine.fr"

# ─── Discord Webhooks (optionnels) ────────────────────────────────────────────
# Webhook du canal #recrutement (staff) — notifications candidatures
# Créer via : Discord → canal → Paramètres → Intégrations → Webhook
# DISCORD_RECRUITMENT_WEBHOOK_URL="https://discord.com/api/webhooks/xxx/yyy"
#
# Webhook du canal événements — notifications calendrier opérations
# DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/xxx/yyy"

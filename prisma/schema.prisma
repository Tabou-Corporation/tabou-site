// ─── Prisma Schema — Tabou Corporation ───────────────────────────────────────
//
// V2 : Auth (User, Account, Session) + rôle membre
// V3 : + Application (candidatures)
// V4 : + Announcement, Guide, CalendarEvent
// V5 : + AuditLog (actif), Permission (à venir)
// V6 : + Character (ESI), Kill (zKillboard)
// V7 : + securityStatus + profileExtra on User ; assignedToId on Application

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon : décommentez la ligne suivante pour le mode serverless
  // directUrl = env("DIRECT_URL")
}

// ─── Auth.js — tables standard ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Tabou — User ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  /// Nom du personnage EVE (issu du SSO)
  name          String?
  /// Non fourni par EVE SSO — toujours null
  email         String?   @unique
  emailVerified DateTime?
  /// URL du portrait EVE (images.evetech.net)
  image         String?
  /// Rôle dans la corporation — valeurs : candidate | member_uz | member | officer | director | ceo | admin
  role          String    @default("candidate")
  /// Spécialité officer — pvp | pve | industry | exploration | communication | recruitment
  specialty     String?
  /// Présentation personnelle (max 160 caractères)
  bio           String?   @db.VarChar(160)
  /// ID de la corporation EVE actuelle (issu de l'ESI au login)
  corporationId  Int?
  /// Statut de sécurité EVE (-10.0 → +5.0) — mis à jour à chaque login
  securityStatus Float?
  /// Profil étendu JSON : { timezone, languages[], mainActivity, alts[] }
  profileExtra   String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  applications         Application[]
  assignedApplications Application[] @relation("AssignedRecruiter")
  announcements        Announcement[]
  guides               Guide[]
  events               CalendarEvent[]
  eventParticipations  EventParticipation[]

  @@index([role])
  @@map("users")
}

// ─── V3 : Applications (recrutement) ─────────────────────────────────────────

model Application {
  id          String            @id @default(cuid())
  userId      String
  status      ApplicationStatus @default(PENDING)
  /// Skillpoints déclarés par le candidat
  spCount       Int?
  /// Pseudo Discord du candidat (pour contact recruteur)
  discordHandle String?
  /// Disponibilités / timezone déclarées par le candidat
  availability  String?
  /// Texte de motivation
  motivation    String?         @db.Text
  /// Notes internes recruteur
  notes         String?         @db.Text
  /// Date/heure de l'entretien Discord (optionnel)
  interviewAt   DateTime?
  /// Recruteur assigné (userId)
  assignedToId  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  reviewedAt  DateTime?
  reviewedBy  String?

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTo  User?             @relation("AssignedRecruiter", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status])
  @@map("applications")
}

enum ApplicationStatus {
  PENDING
  INTERVIEW
  ACCEPTED
  REJECTED
}

// ─── V4 : Annonces ────────────────────────────────────────────────────────────

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  /// Épinglée sur le dashboard membre
  pinned    Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([pinned, createdAt])
  @@map("announcements")
}

// ─── V4 : Guides internes ─────────────────────────────────────────────────────

model Guide {
  id        String   @id @default(cuid())
  title     String
  /// Catégorie : general | pvp | logistics | fits | other
  category  String   @default("general")
  content   String   @db.Text
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("guides")
}

// ─── V4 : Calendrier opérations ───────────────────────────────────────────────

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  startAt     DateTime
  endAt       DateTime?
  /// Type : op | training | social | other
  type              String    @default("op")
  /// Récurrence : none | weekly | biweekly | monthly
  recurrence        String    @default("none")
  /// Date de fin de récurrence (null = pas de récurrence)
  recurrenceEndAt   DateTime?
  authorId          String
  createdAt         DateTime  @default(now())

  author         User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  participations EventParticipation[]

  @@index([startAt])
  @@index([recurrence])
  @@map("calendar_events")
}

// ─── V6 : RSVP événements ─────────────────────────────────────────────────────

model EventParticipation {
  id        String              @id @default(cuid())
  userId    String
  eventId   String
  status    ParticipationStatus @default(GOING)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId])
  @@map("event_participations")
}

enum ParticipationStatus {
  GOING
  MAYBE
  NOT_GOING
}

// ─── V5 : Audit Log ───────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  /// Qui a effectué l'action (userId)
  actorId   String
  /// Nom du personnage au moment de l'action (dénormalisé pour lisibilité)
  actorName String?
  /// Type d'action : role_change | application_status | application_notes
  action    String
  /// Données de contexte JSON (avant/après, cible, etc.)
  meta      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── V5 : CMS — Contenu éditorial ────────────────────────────────────────────

model SiteContent {
  /// Clé de page : home | corporation | recruitment | faq | activities | contact
  page      String   @id
  /// Contenu JSON sérialisé (deep-merged avec les defaults au chargement)
  content   String   @db.Text
  updatedBy String?
  updatedAt DateTime @updatedAt

  @@map("site_content")
}


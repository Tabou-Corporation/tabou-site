// ─── Prisma Schema — Tabou Corporation ───────────────────────────────────────
//
// V2 : Auth (User, Account, Session) + rôle membre
// V3 : + Application (candidatures)
// V4 : + Announcement, Guide, CalendarEvent
// V5 : + AuditLog (actif), Permission (à venir)
// V6 : + Character (ESI), Kill (zKillboard)
// V7 : + securityStatus + profileExtra on User ; assignedToId on Application
// V8 : specialty → specialties (JSON array), domain on Announcement/CalendarEvent
// V9 : + MarketListing, MarketOffer (marché entre membres)
// V10 : + Notification, MarketTransaction (suivi pro du marché)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon : décommentez la ligne suivante pour le mode serverless
  // directUrl = env("DIRECT_URL")
}

// ─── Auth.js — tables standard ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Tabou — User ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  /// Nom du personnage EVE (issu du SSO)
  name          String?
  /// Non fourni par EVE SSO — toujours null
  email         String?   @unique
  emailVerified DateTime?
  /// URL du portrait EVE (images.evetech.net)
  image         String?
  /// Rôle dans la corporation — valeurs : candidate | member_uz | member | officer | director | ceo | admin
  role          String    @default("candidate")
  /// Domaines officier — JSON array : ["pvp","pve","industry","exploration","diplomacy","recruitment"]
  specialties   String?
  /// Présentation personnelle (max 160 caractères)
  bio           String?   @db.VarChar(160)
  /// Character ID EVE (issu du SSO) — unique, empêche les doublons de comptes
  eveCharacterId String?   @unique
  /// ID de la corporation EVE actuelle (issu de l'ESI au login)
  corporationId  Int?
  /// Statut de sécurité EVE (-10.0 → +5.0) — mis à jour à chaque login
  securityStatus Float?
  /// Profil étendu JSON : { timezone, languages[], mainActivity, alts[] }
  profileExtra   String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  applications         Application[]
  assignedApplications Application[] @relation("AssignedRecruiter")
  announcements        Announcement[]
  guides               Guide[]
  events               CalendarEvent[]
  eventParticipations  EventParticipation[]
  assemblies           Assembly[]
  marketListings       MarketListing[]
  marketOffers         MarketOffer[]
  notifications        Notification[]
  transactionsAsSeller MarketTransaction[] @relation("TransactionSeller")
  transactionsAsBuyer  MarketTransaction[] @relation("TransactionBuyer")

  @@index([role])
  @@map("users")
}

// ─── V3 : Applications (recrutement) ─────────────────────────────────────────

model Application {
  id          String            @id @default(cuid())
  userId      String
  status      ApplicationStatus @default(PENDING)
  /// Skillpoints déclarés par le candidat
  spCount       Int?
  /// Pseudo Discord du candidat (pour contact recruteur)
  discordHandle String?
  /// Disponibilités / timezone déclarées par le candidat
  availability  String?
  /// Texte de motivation
  motivation    String?         @db.Text
  /// Notes internes recruteur
  notes         String?         @db.Text
  /// Date/heure de l'entretien Discord (optionnel)
  interviewAt   DateTime?
  /// Recruteur assigné (userId)
  assignedToId  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  reviewedAt  DateTime?
  reviewedBy  String?

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTo  User?             @relation("AssignedRecruiter", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status])
  @@index([assignedToId])
  @@map("applications")
}

enum ApplicationStatus {
  PENDING
  INTERVIEW
  ACCEPTED
  REJECTED
}

// ─── V4 : Annonces ────────────────────────────────────────────────────────────

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  /// Domaine : pvp | pve | industry | exploration | diplomacy | general
  domain    String   @default("general")
  /// Épinglée sur le dashboard membre
  pinned    Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([pinned, createdAt])
  @@map("announcements")
}

// ─── V4 : Guides internes ─────────────────────────────────────────────────────

model Guide {
  id        String   @id @default(cuid())
  title     String
  /// Catégorie : general | pvp | logistics | fits | other
  category  String   @default("general")
  content   String   @db.Text
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("guides")
}

// ─── V4 : Calendrier opérations ───────────────────────────────────────────────

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  startAt     DateTime
  endAt       DateTime?
  /// Type : op | training | social | other
  type              String    @default("op")
  /// Domaine : pvp | pve | industry | exploration | diplomacy | general
  domain            String    @default("general")
  /// Récurrence : none | weekly | biweekly | monthly
  recurrence        String    @default("none")
  /// Date de fin de récurrence (null = pas de récurrence)
  recurrenceEndAt   DateTime?
  authorId          String
  createdAt         DateTime  @default(now())

  author         User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  participations EventParticipation[]

  @@index([startAt])
  @@index([recurrence])
  @@map("calendar_events")
}

// ─── V6 : RSVP événements ─────────────────────────────────────────────────────

model EventParticipation {
  id        String              @id @default(cuid())
  userId    String
  eventId   String
  status    ParticipationStatus @default(GOING)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
  @@map("event_participations")
}

enum ParticipationStatus {
  GOING
  MAYBE
  NOT_GOING
}

// ─── V7 : Assemblées (comptes rendus de réunion) ─────────────────────────────

model Assembly {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  /// URL vers l'enregistrement vidéo (YouTube, Twitch, etc.) — optionnel
  videoUrl  String?
  /// Type : monthly | extraordinary
  type      String   @default("monthly")
  /// Date à laquelle la réunion a eu lieu
  heldAt    DateTime
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([heldAt])
  @@map("assemblies")
}

// ─── V9 : Marché entre membres ────────────────────────────────────────────

model MarketListing {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Type d'annonce : SELL (je vends), BUY (je cherche), EXCHANGE (j'échange)
  type          ListingType    @default(SELL)
  /// Titre court de l'annonce
  title         String
  /// Description / précisions (optionnel)
  description   String?        @db.Text

  /// Copier-coller brut depuis EVE (conservé pour référence)
  rawPaste      String?        @db.Text
  /// Détail parsé : [{name, quantity, typeId, jitaBuy, jitaSell, totalBuy}]
  items         String?        @db.Text
  /// Nombre d'items distincts
  itemCount     Int            @default(0)

  /// Valeur totale Jita buy (prix de référence, informatif)
  totalJitaBuy  Float?
  /// Prix demandé en ISK (fixé par le vendeur — null = ouvert aux offres)
  askingPrice   Float?
  /// Ou taux en % du Jita buy (ex: 90 = 90%) — null = prix fixe ou libre
  askingRate    Int?

  /// Localisation des items (station ou citadelle, texte libre)
  location      String?

  /// Statut de l'annonce
  status        ListingStatus  @default(OPEN)

  /// Expiration obligatoire (max now + 14 jours)
  expiresAt     DateTime

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  offers        MarketOffer[]
  transactions  MarketTransaction[]

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@index([type, status])
  @@map("market_listings")
}

model MarketOffer {
  id          String       @id @default(cuid())
  listingId   String
  listing     MarketListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Prix proposé en ISK (null si échange ou simple message)
  price       Float?
  /// Message de l'offre (description de l'échange, commentaire, négociation)
  message     String?      @db.Text

  /// Statut de l'offre
  status      OfferStatus  @default(PENDING)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt

  transaction MarketTransaction?

  @@index([listingId])
  @@index([userId])
  @@index([status])
  @@map("market_offers")
}

enum ListingType {
  SELL
  BUY
  EXCHANGE
}

enum ListingStatus {
  OPEN
  SOLD
  CLOSED
  EXPIRED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

// ─── V10 : Notifications + Transactions ───────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  /// Destinataire
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Type : offer_received | offer_accepted | offer_rejected | listing_sold | listing_expired
  type      String
  /// Titre court affiché dans la liste
  title     String
  /// Corps optionnel (message complémentaire)
  body      String?
  /// Lien vers la ressource (ex: /membre/marche/clxyz123)
  href      String?

  /// Marque de lecture
  read      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model MarketTransaction {
  id            String   @id @default(cuid())

  /// Annonce d'origine
  listingId     String
  listing       MarketListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  /// Offre acceptée
  offerId       String   @unique
  offer         MarketOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  /// Vendeur (propriétaire de l'annonce)
  sellerId      String
  seller        User     @relation("TransactionSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  /// Acheteur (auteur de l'offre)
  buyerId       String
  buyer         User     @relation("TransactionBuyer", fields: [buyerId], references: [id], onDelete: Cascade)

  /// Snapshot dénormalisé — survit même si l'annonce est supprimée
  listingTitle  String
  listingType   String
  finalPrice    Float?
  itemCount     Int      @default(0)
  location      String?

  createdAt     DateTime @default(now())
  /// Soft-delete : archivée par un admin (masquée des vues membres)
  archivedAt    DateTime?

  @@index([sellerId])
  @@index([buyerId])
  @@index([createdAt])
  @@map("market_transactions")
}

// ─── V5 : Audit Log ───────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  /// Qui a effectué l'action (userId)
  actorId   String
  /// Nom du personnage au moment de l'action (dénormalisé pour lisibilité)
  actorName String?
  /// Type d'action : role_change | application_status | application_notes
  action    String
  /// Données de contexte JSON (avant/après, cible, etc.)
  meta      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── V5 : CMS — Contenu éditorial ────────────────────────────────────────────

model SiteContent {
  /// Clé de page : home | corporation | recruitment | faq | activities | contact
  page      String   @id
  /// Contenu JSON sérialisé (deep-merged avec les defaults au chargement)
  content   String   @db.Text
  updatedBy String?
  updatedAt DateTime @updatedAt

  @@map("site_content")
}


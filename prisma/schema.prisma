// ─── Prisma Schema — Tabou Corporation ───────────────────────────────────────
//
// V2 : Auth (User, Account, Session) + rôle membre
// V3 : + Application (candidatures)
// V4 : + Announcement, Guide, CalendarEvent
// V5 : + AuditLog, Permission
// V6 : + Character (ESI), Kill (zKillboard)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon : décommentez la ligne suivante pour le mode serverless
  // directUrl = env("DIRECT_URL")
}

// ─── Auth.js — tables standard ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Tabou — User ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  /// Nom du personnage EVE (issu du SSO)
  name          String?
  /// Non fourni par EVE SSO — toujours null
  email         String?   @unique
  emailVerified DateTime?
  /// URL du portrait EVE (images.evetech.net)
  image         String?
  /// Rôle dans la corporation — valeurs : candidate | member_uz | member | officer | director | ceo | admin
  role          String    @default("candidate")
  /// Spécialité officer — pvp | pve | industry | exploration | communication | recruitment
  specialty     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  applications  Application[]
  announcements Announcement[]
  guides        Guide[]
  events        CalendarEvent[]

  @@map("users")
}

// ─── V3 : Applications (recrutement) ─────────────────────────────────────────

model Application {
  id          String            @id @default(cuid())
  userId      String
  status      ApplicationStatus @default(PENDING)
  /// Skillpoints déclarés par le candidat
  spCount     Int?
  /// Texte de motivation
  motivation  String?           @db.Text
  /// Notes internes recruteur
  notes       String?           @db.Text
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  reviewedAt  DateTime?
  reviewedBy  String?

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("applications")
}

enum ApplicationStatus {
  PENDING
  INTERVIEW
  ACCEPTED
  REJECTED
}

// ─── V4 : Annonces ────────────────────────────────────────────────────────────

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  /// Épinglée sur le dashboard membre
  pinned    Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("announcements")
}

// ─── V4 : Guides internes ─────────────────────────────────────────────────────

model Guide {
  id        String   @id @default(cuid())
  title     String
  /// Catégorie : general | pvp | logistics | fits | other
  category  String   @default("general")
  content   String   @db.Text
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("guides")
}

// ─── V4 : Calendrier opérations ───────────────────────────────────────────────

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  startAt     DateTime
  endAt       DateTime?
  /// Type : op | training | social | other
  type        String    @default("op")
  authorId    String
  createdAt   DateTime  @default(now())

  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("calendar_events")
}

// ─── V5 : CMS — Contenu éditorial ────────────────────────────────────────────

model SiteContent {
  /// Clé de page : home | corporation | recruitment | faq | activities | contact
  page      String   @id
  /// Contenu JSON sérialisé (deep-merged avec les defaults au chargement)
  content   String   @db.Text
  updatedBy String?
  updatedAt DateTime @updatedAt

  @@map("site_content")
}

